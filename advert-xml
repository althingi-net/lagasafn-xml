#!/usr/bin/env python3
from lagasafn.utils import setup_django
setup_django()

import click
from datetime import datetime
from datetime import timedelta
from djalthingi.models import Document
from lagasafn.advert.commands import apply_intents_from_advert
from lagasafn.advert.commands import convert_adverts
from lagasafn.advert.commands import create_index
from lagasafn.advert.remote import update_local_adverts
from lagasafn.constants import CURRENT_PARLIAMENT_VERSION
from lagasafn.models import LawManager
from lagasafn.models.advert import AdvertManager


def help():
    ctx = click.get_current_context()
    click.echo(ctx.get_help())
    quit(2)


@click.command()
@click.option(
    "--full",
    is_flag=True,
    help="Runs --retrieve, --convert and --make-index, in that order.",
)
@click.option(
    "--retrieve",
    is_flag=True,
    help="Retrieves and saves remote advers on the local disk in a cleaned XML format.",
)
@click.option(
    "--convert",
    is_flag=True,
    help="Converts local adverts into their corresponding XML files.",
)
@click.option("--make-index", is_flag=True, help="Create index of adverts.")
@click.option(
    "--apply", is_flag=True, help="Apply intents from adverts to their target laws."
)
@click.option(
    "--codex-version",
    default=None,
    help="Codex version to use when applying intents or comparing (e.g., '156a'). Defaults to CURRENT_PARLIAMENT_VERSION.",
)
@click.argument("advert_identifiers", nargs=-1)
def main(
    full: bool,
    retrieve: bool,
    convert: bool,
    make_index: bool,
    apply: bool,
    codex_version: str | None,
    advert_identifiers: tuple,
):

    # We don't like tuples around here.
    identifiers = list(advert_identifiers)

    # Make sure that the parameters make sense.
    if not any([full, retrieve, convert, make_index, apply]):
        help()

    # Expand the special "--full" option.
    if full:
        retrieve = True
        convert = True
        make_index = True

    if codex_version is None:
        codex_version = CURRENT_PARLIAMENT_VERSION

    if codex_version not in LawManager.codex_versions():
        raise Exception("Unavailable codex version: %s" % codex_version)

    # We'll handle adverts that were published after the currently selected
    # codex version was released.
    law_index = LawManager.index(codex_version)
    from_date = law_index.info.date_to + timedelta(days=1)

    next_codex_version = LawManager.get_next_codex_version(codex_version)
    if next_codex_version is not None:
        new_law_index = LawManager.index(next_codex_version)
        to_date = new_law_index.info.date_to
    else:
        to_date = datetime.now()

    # Figure out which identifiers we are working with if none are provided.
    if len(identifiers) == 0:
        identifiers = [d.law_identifier for d in Document.objects.filter(
            law_time_published__gte=from_date,
            law_time_published__lt=to_date
        )]

    existing_identifiers = [d.law_identifier for d in Document.objects.filter(law_identifier__in=identifiers)]
    if len(existing_identifiers) != len(identifiers):
        print("Could not find laws in database with the following identifiers:")
        for identifier in identifiers:
            if identifier not in existing_identifiers:
                print(" - %s" % identifier)
        quit(1)

    # Make sure that laws according to these identifiers actually exist.
    if len(identifiers) == 0:
        raise Exception("Couldn't find law identifiers to work with.")

    if retrieve:
        update_local_adverts(from_date, to_date)
    if convert:
        convert_adverts(identifiers)
    if make_index:
        create_index()
    if apply:
        if identifiers:
            # Apply intents from specific adverts
            for advert_id in identifiers:
                apply_intents_from_advert(advert_id)
        else:
            # Apply intents from all adverts
            if codex_version:
                # Apply intents from all adverts for the specified codex version
                codex_versions = [codex_version]
            else:
                # Apply intents from all adverts for all codex versions
                codex_versions = LawManager.codex_versions()

            for codex_version in codex_versions:
                print(f"Applying adverts for codex version: {codex_version}")
                index = AdvertManager.index(codex_version)
                for advert in index.adverts:
                    apply_intents_from_advert(advert.identifier)


if __name__ == "__main__":
    main()
